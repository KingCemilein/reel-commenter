<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reel Commenter PRO"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Heute: 0 | Total: 0"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Auto-Modus = Riskant! Max. 20-30 Kommentare/Stunde!"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/autoModeCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Auto-Modus (postet beim Öffnen eines Reels)"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️ Smart Delay (Min - Max Sekunden):"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <NumberPicker
                android:id="@+id/minDelayPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" bis "
                android:layout_gravity="center_vertical" />

            <NumberPicker
                android:id="@+id/maxDelayPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Kommentar-Pool 1 (Komma getrennt):"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pool1Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:gravity="top"
            android:hint="Passt auf euch auf, Passt auf euch auf 🙏"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Kommentar-Pool 2:"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pool2Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:gravity="top"
            android:hint="Passt gut auf euch auf, Bleibt gesund!"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Kommentar-Pool 3:"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/pool3Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:gravity="top"
            android:hint="Passt auf euch auf! ❤️, Coole Reels!"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 Aktiver Pool:"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/poolSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <CheckBox
                android:id="@+id/soundCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 Sound"
                android:checked="true" />

            <CheckBox
                android:id="@+id/vibrationCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📳 Vibration"
                android:checked="true" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/fallbackCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Koordinaten-Fallback (X=85 Y=88)"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/accessibilityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility-Service aktivieren"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Schwebenden Button starten"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Button stoppen"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/resetStatsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Statistik zurücksetzen"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bedienung: Auto-Modus = du swipst, App postet. Manuell = pinken Button drücken. Warte IMMER zwischen Kommentaren!"
            android:textSize="12sp"
            android:textColor="#666666" />

    </LinearLayout>
</ScrollView>
