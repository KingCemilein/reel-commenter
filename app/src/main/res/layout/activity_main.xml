<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reel Commenter"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Heute: 0  |  Total: 0"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌍 Sprache / Language"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/languageSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ Standard-Kommentar:"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/commentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passt auf euch auf"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Kommentar-Liste (mit Komma trennen):"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/commentListInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:hint="Passt auf euch auf, Passt gut auf euch auf, ..."
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️ Mindestpause (Sekunden):"
            android:textStyle="bold" />

        <NumberPicker
            android:id="@+id/delayPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Koordinaten-Fallback (wenn Button nicht gefunden):"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X:" />

            <NumberPicker
                android:id="@+id/fallbackXPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y:" />

            <NumberPicker
                android:id="@+id/fallbackYPicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X=85%, Y=88% ist meist unten rechts"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/fallbackToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Koordinaten-Fallback aktivieren"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wichtig: Aktiviere zuerst den Accessibility-Service!"
            android:textColor="#FF0000"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/accessibilityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility-Service aktivieren"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Schwebenden Button starten"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Button stoppen"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/resetStatsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Statistik zurücksetzen"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bedienung: Öffne Instagram, gehe zu einem Reel und tippe auf den pinken schwebenden Button. Warte mindestens 12 Sekunden zwischen Kommentaren! Der Button zeigt einen Countdown an."
            android:textSize="12sp"
            android:textColor="#888888" />

    </LinearLayout>
</ScrollView>
